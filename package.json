{
  "name": "gitbackup-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "coverage": "turbo run coverage",
    "validate": "turbo run validate",
    "dev": "turbo run dev",
    "start": "turbo run start --filter=gitbackup-cli",
    "prepare": "git config --unset core.hooksPath >/dev/null 2>&1; lefthook install || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@types/node": "^20.14.18",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.25.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.5.3",
    "turbo": "^2.9.14",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.30.1",
    "vitest": "^4.1.9"
  },
  "packageManager": "npm@10.8.2"
}